# ── Base de données ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/soro_db?sslmode=require"

# ── Authentification ─────────────────────────────────────────
JWT_SECRET="changez-moi-en-production-valeur-longue-aleatoire"
JWT_EXPIRES_IN="7d"

# ── Serveur ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ── AfricasTalking (SMS, USSD, appels vocaux) ─────────────────
AT_API_KEY="votre-cle-api-africastalking"
AT_USERNAME="sandbox"  # "soro" en production
AT_SENDER_ID="SORO"

# ── CinetPay (Orange Money, Moov Money — escrow) ──────────────
CINETPAY_API_KEY="votre-cle-api-cinetpay"
CINETPAY_SITE_ID="votre-site-id-cinetpay"
CINETPAY_BASE_URL="https://api-checkout.cinetpay.com/v2"
CINETPAY_NOTIFY_URL="https://votre-domaine.railway.app/webhooks/cinetpay"

# ── Cloudinary (stockage photos) ──────────────────────────────
CLOUDINARY_CLOUD_NAME="votre-cloud-name"
CLOUDINARY_API_KEY="votre-api-key-cloudinary"
CLOUDINARY_API_SECRET="votre-api-secret-cloudinary"

# ── Open-Meteo (météo gratuite) ───────────────────────────────
# Pas de clé nécessaire — API publique gratuite
OPEN_METEO_BASE_URL="https://api.open-meteo.com/v1"
